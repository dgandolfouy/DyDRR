rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - displayName: string
    //   - role: string (required, ['admin', 'auditor', 'viewer'])
    //   - createdAt: timestamp
    //
    // Collection: projects
    // Document ID: {projectId}
    // Fields:
    //   - code: string (required, e.g., DD0001)
    //   - title: string (required)
    //   - description: string
    //   - source: string (required, ['COMMERCIAL', 'PRODUCTION', 'RECLAMO', 'ARTE', 'GERENCIA', 'CALIDAD'])
    //   - currentStep: int (required, 1-8)
    //   - status: string (required, ['ACTIVE', 'APPROVED', 'REJECTED', 'EN_REVISION'])
    //   - planning: map
    //   - execution: map
    //   - controls: map
    //   - outputs: map
    //   - validation: map
    //   - history: list
    //   - coordinationLog: list
    //   - versionChanges: list
    //   - trelloLink: string
    //   - createdBy: string (required)
    //   - createdAt: string (ISO string)
    //   - updatedAt: string (ISO string)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isBootstrapAdmin() {
      return isAuthenticated() &&
             request.auth.token.email == "daniel.gandolfo@gmail.com";
    }

    function isAdmin() {
      return isBootstrapAdmin() || 
             (isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isAuditor() {
      return isAdmin() || 
             (isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'auditor');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'auditor', 'viewer'];
    }

    function isValidProjectCreate(data) {
      return data.keys().hasAll(['code', 'title', 'source', 'currentStep', 'status', 'createdBy', 'createdAt', 'updatedAt', 'planning', 'history']) &&
             data.code is string &&
             data.title is string &&
             data.source in ['COMMERCIAL', 'PRODUCTION', 'RECLAMO', 'ARTE', 'GERENCIA', 'CALIDAD'] &&
             data.currentStep is number &&
             data.status in ['ACTIVE', 'APPROVED', 'REJECTED', 'EN_REVISION'] &&
             data.createdBy is string &&
             data.planning is map &&
             data.history is list;
    }

    function isValidProjectUpdate(data) {
      // Robust check for updates, allowing partial updates to pass validation
      return (data.get('code', '') is string) &&
             (data.get('title', '') is string) &&
             (data.get('currentStep', 1) is number) &&
             (data.get('status', 'ACTIVE') is string);
    }

    function isValidRevision(data) {
      return data.keys().hasAll(['projectId', 'userId', 'comment', 'timestamp']) &&
             data.projectId is string &&
             data.userId is string &&
             data.comment is string &&
             data.timestamp is timestamp;
    }

    function isValidMedia(data) {
      return data.keys().hasAll(['projectId', 'step', 'url', 'type', 'createdAt', 'name']) &&
             data.projectId is string &&
             data.step is number &&
             data.url is string &&
             data.type is string &&
             data.name is string &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'viewer' || (isBootstrapAdmin() && request.resource.data.role == 'admin'));
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && 
                    (isAdmin() || request.resource.data.role == resource.data.role);
    }

    match /projects/{projectId} {
      allow read, write: if isBootstrapAdmin();
      allow read: if isAuthenticated();
      allow create: if isAuditor() && isValidProjectCreate(request.resource.data);
      allow update: if isAuditor() && isValidProjectUpdate(request.resource.data);
      allow delete: if isAdmin();

      match /revisions/{revisionId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidRevision(request.resource.data);
      }

      match /media/{mediaId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isValidMedia(request.resource.data);
        allow delete: if isAdmin();
      }
    }
  }
}
